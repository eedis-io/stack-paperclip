# Auto-generated from env-config.yaml — DO NOT EDIT MANUALLY
# Regenerate with: stack-setup setup paperclip
# This file is safe to commit to version control (no secrets)
#
# Run stack-setup setup to generate .env.local, .env.dev and .env.prod with actual values

# Auto-generated secrets and keys
# Signing key for authentication sessions
BETTER_AUTH_SECRET=<generated:hex:32>
# PostgreSQL password for the paperclip database user
POSTGRES_PASSWORD=<generated:password:24>

# Configuration
# Docker image met tag — update bij upgrades
IMAGE=tuyenvd/paperclip:v2026.403.0
# Authentication mode: 'authenticated' or 'unauthenticated'
PAPERCLIP_DEPLOYMENT_MODE=authenticated
# Deployment exposure: 'private' or 'public'
PAPERCLIP_DEPLOYMENT_EXPOSURE=private

# Environment-specific overrides (production examples)
PORT=443
DOMAIN=paperclip.{CLIENT_ID}.eedis.io
PAPERCLIP_PUBLIC_URL=https://paperclip.{CLIENT_ID}.eedis.io

# Computed (set automatically during generation)
CLIENT_ID=<your-client-id>
STACK_NAME=paperclip
COMPOSE_PROJECT_NAME=<client-id>-paperclip

